# API
PORT=8787

# Casper integration.
# Default mode is mock so the app runs without secrets.
CASPER_MODE=mock
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_KEY_ALGORITHM=ED25519

# Use one of these only for real testnet transactions.
# Never commit a funded private key.
CASPER_PRIVATE_KEY_HEX=
CASPER_PRIVATE_KEY_PEM=
CASPER_PRIVATE_KEY_PEM_FILE=

# Native transfer attestation settings.
# The transfer id is derived from the report hash and acts as an on-chain memo.
CASPER_TRANSFER_AMOUNT_MOTES=2500000000
CASPER_PAYMENT_MOTES=100000000
CASPER_EXPLORER_BASE_URL=https://testnet.cspr.live/transaction

# Optional after deploying contracts/risk-registry.
CASPER_RISK_REGISTRY_HASH=
